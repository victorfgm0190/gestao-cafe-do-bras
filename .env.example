# Credenciais da integração Bling (API v3)
# Copie para .env em desenvolvimento e configure as MESMAS variáveis no painel da Vercel.
# NUNCA comite o .env — o client secret é sigiloso.

BLING_CLIENT_ID=dabc88366c8f114c52d879fda136226df634b7fc
BLING_CLIENT_SECRET=coloque_o_client_secret_aqui
BLING_REDIRECT_URI=https://gestao-cafe-do-bras.vercel.app/bling/callback
BLING_BASE_URL=https://www.bling.com.br/Api/v3

# Tokens iniciais (opcional): usados só como "semente" caso o Redis esteja vazio.
# A persistência real é feita no Upstash Redis após a 1ª autorização.
BLING_ACCESS_TOKEN=
BLING_REFRESH_TOKEN=

# Upstash Redis — injetadas automaticamente pela integração Upstash da Vercel.
# Em desenvolvimento local, copie os valores do painel da Vercel/Upstash.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# PostgreSQL (Neon) — connection string usada por api/db.js.
# Já configurada no painel da Vercel; para rodar/migrar localmente, copie o valor de lá.
DATABASE_URL=
